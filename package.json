{
	"name": "remind-me",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "src/electron/main.js",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "eslint .",
		"electron": "electron .",
		"electron:dev": "concurrently \"vite dev\" \"wait-on http://localhost:5173 && electron .\"",
		"android": "vite build && npx cap sync android && npx cap run android"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.3.0",
		"@electron/rebuild": "^4.0.3",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22",
		"concurrently": "^9.2.1",
		"electron": "^41.2.0",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"svelte": "^5.55.2",
		"vite": "^8.0.7",
		"wait-on": "^9.0.4"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/preferences": "^8.0.1",
		"better-sqlite3": "^12.8.0",
		"is-electron": "^2.2.2"
	}
}
