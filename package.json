{
	"name": "remind-me",
	"private": true,
	"description": "Minimal App to set reminders",
	"author": {},
	"version": "0.8.0",
	"type": "module",
	"main": "src/electron/main.js",
	"scripts": {
		"prepare": "svelte-kit sync || echo ''",
		"lint": "eslint .",
		"electron:dev": "electron-rebuild && vite build && concurrently \"vite dev\" \"wait-on http://localhost:5173 && electron .\"",
		"electron:build": "electron-rebuild && vite build && electron-builder -l tar.xz -w nsis",
		"electron:build-linux": "electron-rebuild && vite build && electron-builder -l tar.xz",
		"electron:build-windows": "electron-rebuild && vite build && electron-builder -w nsis",
		"electron:dist": "electron-rebuild && vite build && electron-builder",
		"android:dev": "vite build && cap sync android && cap run android",
		"android:build": "vite build && cap sync android && cd android && ./gradlew build && cp app/build/outputs/apk/debug/app-debug.apk ../remind_me-android.apk",
		"android:dist": "vite build && cap sync android && cap build android --androidreleasetype APK",
		"backend:dev": "node --watch --experimental-sqlite src/backend/main.js",
		"backend:prod": "node --experimental-sqlite src/backend/main.js",
		"postinstall": "electron-rebuild"
	},
	"build": {
		"npmRebuild": true,
		"buildDependenciesFromSource": true,
		"appId": "dev.delfi.remind_me",
		"productName": "Remind Me",
		"directories": {
			"output": "dist",
			"buildResources": "build"
		},
		"files": [
			"dist/**/*",
			"dist-electron/**/*",
			"!**/*.map",
			"!**/test/**",
			"!**/*.md",
			"src/electron/**/*",
			"src/**/**/**"
		],
		"asar": true,
		"asarUnpack": [
			"**/*.node"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"category": "public.app-category.productivity",
			"artifactName": "${productName}-${version}-${arch}.${ext}"
		},
		"dmg": {
			"title": "${productName} ${version}",
			"iconSize": 128,
			"contents": [
				{
					"x": 130,
					"y": 220
				},
				{
					"x": 410,
					"y": 220,
					"type": "link",
					"path": "/Applications"
				}
			]
		},
		"linux": {
			"target": [
				{
					"target": "AppImage",
					"arch": [
						"x64"
					]
				},
				{
					"target": "deb",
					"arch": [
						"x64"
					]
				},
				{
					"target": "rpm",
					"arch": [
						"x64"
					]
				},
				{
					"target": "pacman",
					"arch": [
						"x64"
					]
				},
				{
					"target": "flatpak",
					"arch": [
						"x64"
					]
				}
			],
			"category": "Utility",
			"artifactName": "${productName}-${version}-${arch}.${ext}",
			"maintainer": "Delfi-CH <delfi@delfi.dev>",
			"synopsis": "Minimal reminder app",
			"description": "A minimal cross-platform reminder application built with Electron and Svelte."
		},
		"deb": {
			"depends": [
				"libnotify4",
				"libnss3",
				"libxss1",
				"libxtst6",
				"xdg-utils",
				"libatspi2.0-0",
				"libuuid1",
				"libsecret-1-0",
				"libappindicator3-1"
			]
		},
		"rpm": {
			"depends": [
				"libnotify",
				"nss",
				"libXScrnSaver",
				"libXtst",
				"xdg-utils",
				"at-spi2-core",
				"libuuid",
				"libsecret",
				"libappindicator"
			]
		},
		"flatpak": {
			"runtime": "org.freedesktop.Platform",
			"runtimeVersion": "25.08",
			"sdk": "org.freedesktop.Sdk",
			"base": "org.electronjs.Electron2.BaseApp",
			"baseVersion": "25.08",
			"finishArgs": [
				"--share=network",
				"--socket=x11",
				"--socket=wayland",
				"--device=dri",
				"--filesystem=home",
				"--talk-name=org.kde.StatusNotifierWatcher"
			]
		},
		"publish": null
	},
	"devDependencies": {
		"@capacitor/cli": "^8.3.0",
		"@electron/rebuild": "^4.0.3",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22",
		"concurrently": "^9.2.1",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"svelte": "^5.55.2",
		"vite": "^8.0.7",
		"wait-on": "^9.0.4"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/device": "^8.0.2",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/preferences": "^8.0.1",
		"better-sqlite3": "^12.8.0",
		"bootstrap": "^5.3.8",
		"bootswatch": "^5.3.8",
		"express": "^5.2.1",
		"is-electron": "^2.2.2",
		"linux-os-info": "^2.0.0"
	}
}